pipeline {
    agent {
        kubernetes {
            yaml '''
            apiVersion: v1
            kind: Pod
            spec:
              containers:
              - name: docker-client
                image: docker:24-cli
                command: ['cat']
                tty: true
              - name: docker-daemon
                image: docker:24-dind
                securityContext:
                  privileged: true
                env:
                - name: DOCKER_TLS_CERTDIR
                  value: ""
              - name: kubectl
                image: bitnami/kubectl:latest
                command: ['cat']
                tty: true
                securityContext:
                  runAsUser: 0
            '''
        }
    }

    environment {
        DOCKER_IMAGE = "bmleon/webcliente:latest"
        PROJECT_DIR  = "Docker/proyectos/web_ukiyo_nuxt"
        K8S_DIR      = "Docker/proyectos/web_ukiyo_nuxt/deploy/kubernetes"
        DOCKER_HOST  = "tcp://localhost:2375"
    }

    stages {
        stage('Construir y Subir Imagen de Nuxt') {
            steps {
                container('docker-client') {
                    script {
                        echo "Iniciando motor Docker..."
                        sh 'while ! docker info >/dev/null 2>&1; do sleep 2; done'
                        
                        dir("${PROJECT_DIR}") {
                            echo "Construyendo la imagen de la tienda..."
                            sh "docker build -t ${DOCKER_IMAGE} -f deploy/Dockerfile ."
                            
                            echo "Subiendo imagen a Docker Hub..."
                            withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', 
                                                            passwordVariable: 'DOCKER_HUB_PASSWORD', 
                                                            usernameVariable: 'DOCKER_HUB_USER')]) {
                                sh "echo \$DOCKER_HUB_PASSWORD | docker login -u \$DOCKER_HUB_USER --password-stdin"
                                sh "docker push ${DOCKER_IMAGE}"
                            }
                        }
                    }
                }
            }
        }

        stage('Desplegar Tienda en Kubernetes') {
            steps {
                container('kubectl') {
                    script {
                        dir("${K8S_DIR}") {
                            echo "Aplicando configuración de Kubernetes..."
                            sh "kubectl apply -f namespace-webcliente.yml"
                            sh "kubectl apply -f deploy-webcliente.yml"
                            sh "kubectl apply -f service-webcliente.yml"
                            sh "kubectl apply -f ingress-webcliente.yml"
                            
                            echo "Forzando reinicio del pod para aplicar cambios de perfil.vue..."
                            // Esta línea asegura que el código viejo se borre del servidor
                            sh "kubectl rollout restart deployment nuxt-web-cliente -n web-cliente"
                        }
                    }
                }
            }
        }
    }

    post {
        success { 
            echo "✅ ¡Tienda actualizada! Recuerda pulsar CTRL+F5 en el navegador para ver los cambios." 
        }
        failure { 
            echo "❌ Error en el despliegue. Revisa los logs de construcción." 
        }
    }
}