pipeline {
    agent {
        kubernetes {
            yaml '''
            apiVersion: v1
            kind: Pod
            spec:
              containers:
              - name: docker-client
                image: docker:24-cli
                command: ['cat']
                tty: true
              - name: docker-daemon
                image: docker:24-dind
                securityContext:
                  privileged: true
                env:
                - name: DOCKER_TLS_CERTDIR
                  value: ""
              - name: kubectl
                image: bitnami/kubectl:latest
                command: ['cat']
                tty: true
                securityContext:
                  runAsUser: 0
            '''
        }
    }

    environment {
        // Nombre de la imagen en Docker Hub
        DOCKER_IMAGE = "bmleon/webcliente:latest"
        // Rutas exactas a tu nueva carpeta en GitHub
        PROJECT_DIR  = "Docker/proyectos/web_ukiyo_nuxt"
        K8S_DIR      = "Docker/proyectos/web_ukiyo_nuxt/deploy/kubernetes"
        DOCKER_HOST  = "tcp://localhost:2375"
    }

    stages {
        stage('Construir y Subir Imagen de Nuxt') {
            steps {
                container('docker-client') {
                    script {
                        echo "Iniciando motor Docker..."
                        sh 'while ! docker info >/dev/null 2>&1; do sleep 2; done'
                        
                        dir("${PROJECT_DIR}") {
                            echo "Construyendo la imagen de la tienda..."
                            // Usa el Dockerfile específico de Nuxt
                            sh "docker build -t ${DOCKER_IMAGE} -f deploy/Dockerfile ."
                            
                            echo "Subiendo imagen a Docker Hub..."
                            withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                                sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin"
                                sh "docker push ${DOCKER_IMAGE}"
                            }
                        }
                    }
                }
            }
        }

        stage('Desplegar Tienda en Kubernetes') {
            steps {
                container('kubectl') {
                    script {
                        dir("${K8S_DIR}") {
                            echo "Aplicando configuración de Kubernetes para la tienda..."
                            sh "kubectl apply -f namespace-webcliente.yml"
                            sh "kubectl apply -f deploy-webcliente.yml"
                            sh "kubectl apply -f service-webcliente.yml"
                            sh "kubectl apply -f ingress-webcliente.yml"
                            
                            echo "¡Archivos aplicados correctamente!"
                        }
                    }
                }
            }
        }
    }

    post {
        success { 
            echo "✅ ¡Tienda Nuxt construida, subida y DESPLEGADA con éxito en Kubernetes!" 
        }
        failure { 
            echo "❌ Error en el Pipeline. Revisa los logs." 
        }
    }
}