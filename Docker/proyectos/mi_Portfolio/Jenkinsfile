pipeline {
    agent {
        kubernetes {
            yaml '''
            apiVersion: v1
            kind: Pod
            spec:
              containers:
              - name: docker-agent
                image: docker:24-dind
                securityContext:
                  privileged: true
                tty: true
            '''
        }
    }

    environment {
        DOCKER_IMAGE = "bmleon/miportfolio:latest"
        PROJECT_DIR  = "Docker/proyectos/mi_Portfolio"
        // Este entorno le dice al agente que use su propio Docker interno (DIND)
        DOCKER_HOST = "tcp://localhost:2375"
    }

    stages {
        stage('Construir y Subir Imagen') {
            steps {
                container('docker-agent') {
                    script {
                        dir("${PROJECT_DIR}") {
                            echo "Construyendo imagen..."
                            // Ahora el agente Docker construirá sin quejarse
                            sh "docker build -t ${DOCKER_IMAGE} -f deploy/Dockerfile ."
                            
                            withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', passwordVariable: 'DOCKER_HUB_PASSWORD', usernameVariable: 'DOCKER_HUB_USER')]) {
                                sh "echo \$DOCKER_HUB_PASSWORD | docker login -u \$DOCKER_HUB_USER --password-stdin"
                                sh "docker push ${DOCKER_IMAGE}"
                            }
                        }
                    }
                }
            }
        }
    }
}