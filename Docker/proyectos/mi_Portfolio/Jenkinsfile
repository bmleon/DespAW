pipeline {
    agent any // Usa directamente el servidor donde corre Jenkins

    environment {
        DOCKER_USER = 'bmleon'
        IMAGE_NAME  = 'miportfolio'
    }

    stages {
        stage('Limpiar Espacio') {
            steps {
                // Borra imágenes antiguas para no llenar el disco de la VPS
                sh "docker system prune -f || true"
            }
        }

        stage('Construir Imagen') {
            steps {
                // Construye la imagen usando el Docker de la VPS
                sh "docker build -t ${DOCKER_USER}/${IMAGE_NAME}:latest -f Docker/proyectos/mi_Portfolio/deploy/Dockerfile ."
            }
        }

        stage('Subir a Docker Hub') {
            steps {
                // Usa las credenciales que ya tienes guardadas en Jenkins
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER_VAR')]) {
                    sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER_VAR --password-stdin"
                    sh "docker push ${DOCKER_USER}/${IMAGE_NAME}:latest"
                }
            }
        }

        stage('Desplegar en Kubernetes') {
            steps {
                // Aplica los archivos YAML usando el microk8s de la VPS
                sh "sudo microk8s kubectl apply -f Docker/proyectos/mi_Portfolio/deploy/kubernetes/"
                // Fuerza el reinicio para que cargue la nueva imagen
                sh "sudo microk8s kubectl rollout restart deployment deploy-miportfolio -n namespace-miportfolio"
            }
        }
    }

    post {
        success {
            echo '¡Despliegue completado con éxito! Revisa la URL de tu portfolio.'
        }
        failure {
            echo 'Algo ha fallado. Revisa los logs de la consola.'
        }
    }
}